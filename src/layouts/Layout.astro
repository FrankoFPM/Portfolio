---
import '../styles/global.css'
import type { Lang } from '../i18n/ui'
interface Props {
  title: string;
  description: string;
  lang: Lang;
}
const { title, description, lang } = Astro.props as Props

const esUrl = new URL('/', Astro.site).href
const enUrl = new URL('/en/', Astro.site).href
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href
const ogImageUrl = new URL('/og.png', Astro.site).href
const ogLocale = lang === 'es' ? 'es_PE' : 'en_US'
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body class="min-h-fit relative">
    <slot />
    <script type="text/javascript">
    document.addEventListener('DOMContentLoaded', () => {
      const header = document.getElementById('main-header');
      if (!header) return;

      let lastScroll = window.scrollY;

      window.addEventListener('scroll', () => {
        const currentScroll = window.scrollY;

        if (currentScroll === 0) {
          header.style.transform = 'translateY(0)';
        } else if (currentScroll < lastScroll) {
          if (currentScroll < 10) {
            header.style.transform = 'translateY(-5px)';
          } else {
            header.style.transform = 'translateY(-5px)';
          }
        } else if (currentScroll > lastScroll) {
          header.style.transform = 'translateY(-80px)';
        }

        if (currentScroll > 0) {
          header.classList.add('shadow-xl/20', 'shadow-black', 'sticky', 'top-0', 'z-50');
        } else {
          header.classList.remove('shadow-xl/20', 'shadow-black');
        }

        lastScroll = currentScroll;
      });
    });
    </script>


  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
