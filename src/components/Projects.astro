---
import { existsSync } from 'node:fs'
import ReactIcon from './icons/ReactIcon.astro'
import TailwindIcon from './icons/TailwindIcon.astro'
import PixiJsIcon from './icons/PixiJsIcon.astro'
import Githubicon from './icons/Githubicon.astro'
import LinkButton from './LinkButton.astro'
import ViteIcon from './icons/ViteIcon.astro'
import LaravelIcon from './icons/LaravelIcon.astro'
import MysqlIcon from './icons/MysqlIcon.astro'
import JavaIcon from './icons/JavaIcon.astro'
import SpringBootIcon from './icons/SpringBootIcon.astro'
import NextjsIcon from './icons/NextjsIcon.astro'
import NestjsIcon from './icons/NestjsIcon.astro'
import PostgresqlIcon from './icons/PostgresqlIcon.astro'
import DockerIcon from './icons/DockerIcon.astro'
import PrismaIcon from './icons/PrismaIcon.astro'
import ElectronIcon from './icons/ElectronIcon.astro'
import AwsIcon from './icons/AwsIcon.astro'
import GcpIcon from './icons/GcpIcon.astro'
import FirebaseIcon from './icons/FirebaseIcon.astro'
import TrpcIcon from './icons/TrpcIcon.astro'
import projects from '../data/projects.json'
import { useTranslations, type Lang } from '../i18n/ui'

const { lang } = Astro.props as { lang: Lang }
const t = useTranslations(lang)

const TAGS = {
  REACT: { name: 'React', class: 'bg-black text-white', icon: ReactIcon },
  TAILWIND: { name: 'Tailwind CSS', class: 'bg-[#003159] text-white', icon: TailwindIcon },
  PIXIJS: { name: 'Pixijs', class: 'bg-[#E72264] text-white', icon: PixiJsIcon },
  VITE: { name: 'Vite', class: 'bg-[#646CFF] text-white', icon: ViteIcon },
  LARAVEL: { name: 'Laravel', class: 'bg-[#FFFF] text-black', icon: LaravelIcon },
  MYSQL: { name: 'MySQL', class: 'bg-[#6cb0bf] text-white', icon: MysqlIcon },
  JAVA: { name: 'Java', class: 'bg-[#D8F8FF] text-black', icon: JavaIcon },
  SPRINGBOOT: { name: 'Spring Boot', class: 'bg-[#506349] text-white', icon: SpringBootIcon },
  NEXTJS: { name: 'Next.js', class: 'bg-black text-white', icon: NextjsIcon },
  NESTJS: { name: 'NestJS', class: 'bg-[#E0234E] text-white', icon: NestjsIcon },
  POSTGRESQL: { name: 'PostgreSQL', class: 'bg-[#336791] text-white', icon: PostgresqlIcon },
  DOCKER: { name: 'Docker', class: 'bg-[#2496ED] text-white', icon: DockerIcon },
  PRISMA: { name: 'Prisma', class: 'bg-[#2D3748] text-white', icon: PrismaIcon },
  ELECTRON: { name: 'Electron', class: 'bg-[#2C3E50] text-white', icon: ElectronIcon },
  AWS: { name: 'AWS', class: 'bg-[#FF9900] text-black', icon: AwsIcon },
  GCP: { name: 'Google Cloud', class: 'bg-[#4285F4] text-white', icon: GcpIcon },
  FIREBASE: { name: 'Firebase', class: 'bg-[#FFCA28] text-black', icon: FirebaseIcon },
  TRPC: { name: 'tRPC', class: 'bg-[#398CCB] text-white', icon: TrpcIcon },
} as const

type TagKey = keyof typeof TAGS

interface Project {
  id: string
  title: string
  org: string
  description: { es: string; en: string }
  link: string
  github: string
  image: string
  tags: string[]
}

// public/ es la raíz de assets estáticos; comprobamos existencia para evitar 404 duro.
const hasImage = (image: string) => existsSync(new URL(`../../public/${image}`, import.meta.url))

const ORG_BADGE: Record<string, string> = {
  'BCP Consulting': 'bg-secondary/10 border-secondary/40 text-secondary',
  Personal: 'bg-white/5 border-white/20 text-white/70',
  Freelance: 'bg-transparent border-dashed border-secondary/40 text-secondary/80',
}

// ponytail: featured project marcado por id, no requiere tocar el schema del JSON
const FEATURED_ID = 'arrendo'
const allProjects = projects as Project[]
const featured = allProjects.find((p) => p.id === FEATURED_ID)
const rest = allProjects.filter((p) => p.id !== FEATURED_ID)
---
<section id="projects" class="my-5">
  <div>
  <h2 id="pj" class="text-3xl font-bold text-white/90 flex items-center my-10">
    <span class="text-secondary mr-2">02.</span> {t('section.projects')}
    <span class="flex-1 h-px bg-white/20 ml-4"></span>
  </h2>
  {
    featured && (
      <article class="mb-16 group box-container">
        <div class="mb-3 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-secondary">
          <span class="h-px w-6 bg-secondary"></span>
          {t('project.featured')}
        </div>
        <div class="flex flex-col overflow-hidden rounded-xl border border-secondary/30 bg-white/5 shadow-2xl md:flex-row">
          <div class="md:w-[55%]">
            {hasImage(featured.image) ? (
              <img
                alt={`Captura de pantalla del proyecto ${featured.title}`}
                class="h-64 w-full object-cover object-top transition duration-500 md:h-full md:group-hover:scale-105"
                src={`/${featured.image}`}
              />
            ) : (
              <div
                class="relative h-64 w-full flex items-center justify-center overflow-hidden bg-gradient-to-br from-background via-[#161a33] to-background md:h-full"
                role="img"
                aria-label={`${featured.title} — sin captura de pantalla disponible`}
              >
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(148,207,251,0.15),transparent_60%)]"></div>
                <div class="flex items-center gap-6 opacity-[0.15]">
                  {featured.tags.slice(0, 3).map((key) => {
                    const tag = TAGS[key as TagKey]
                    if (!tag) return null
                    return <tag.icon class="size-16 text-white" />
                  })}
                </div>
              </div>
            )}
          </div>
          <div class="flex flex-col justify-center p-6 md:w-[45%] md:p-8">
            <div class="flex items-center gap-3">
              <h3 class="text-2xl font-bold text-white/90 title">{featured.title}</h3>
              <span class={`text-xs font-medium px-2 py-0.5 rounded-full border whitespace-nowrap ${ORG_BADGE[featured.org] ?? ORG_BADGE.Personal}`}>{featured.org}</span>
            </div>
            <ul class="mt-3 flex flex-row flex-wrap gap-2">
              {featured.tags.map((key) => {
                const tag = TAGS[key as TagKey]
                if (!tag) return null
                return (
                  <li class="chips">
                    <span class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 transition duration-200 hover:scale-105 hover:brightness-110`}>
                      <tag.icon class="size-4" />
                      {tag.name}
                    </span>
                  </li>
                )
              })}
            </ul>
            <p class="mt-4 text-white/70 leading-relaxed description">{featured.description[lang]}</p>
            <footer class="mt-6 flex items-end justify-start gap-x-4">
              {featured.github && (
                <LinkButton href={featured.github} extraClasses="buttons" ariaLabel={`${t('project.code')}: ${featured.title}`}>
                  <Githubicon class="size-6" />
                  {t('project.code')}
                </LinkButton>
              )}
              {featured.link && (
                <LinkButton href={featured.link} extraClasses="buttons" ariaLabel={`${t('project.view')}: ${featured.title}`}>
                  {t('project.view')}
                </LinkButton>
              )}
            </footer>
          </div>
        </div>
      </article>
    )
  }
  <div class="flex flex-col gap-y-16">
    {
      rest.map(({ image, title, org, description, tags, link, github }) => (
        <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0 box-container">
          <div class="w-full md:w-1/2">
            <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl border border-white/10 md:group-hover:border-secondary/30">
              {hasImage(image) ? (
                <img
                  alt={`Captura de pantalla del proyecto ${title}`}
                  class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
                  src={`/${image}`}
                />
              ) : (
                <div
                  class="relative w-full h-56 sm:h-64 flex items-center justify-center overflow-hidden bg-gradient-to-br from-background via-[#161a33] to-background"
                  role="img"
                  aria-label={`${title} — sin captura de pantalla disponible`}
                >
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(148,207,251,0.15),transparent_60%)]"></div>
                  <div class="flex items-center gap-6 opacity-[0.15] transition-opacity duration-500 md:group-hover:opacity-25">
                    {tags.slice(0, 3).map((key) => {
                      const tag = TAGS[key as TagKey]
                      if (!tag) return null
                      return <tag.icon class="size-16 text-white" />
                    })}
                  </div>
                </div>
              )}
            </div>
          </div>

          <div class="w-full md:w-1/2 md:max-w-lg">
            <div class="flex items-center gap-3">
              <h3 class="text-2xl font-bold text-white/90 title">
                {title}
              </h3>
              <span class={`text-xs font-medium px-2 py-0.5 rounded-full border whitespace-nowrap ${ORG_BADGE[org] ?? ORG_BADGE.Personal}`}>{org}</span>
            </div>
            <div class="flex flex-wrap mt-2">
              <ul class="flex flex-row flex-wrap mb-2 gap-2">
                {tags.map((key) => {
                  const tag = TAGS[key as TagKey]
                  if (!tag) return null
                  return (
                    <li class="chips">
                      <span class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 transition duration-200 hover:scale-105 hover:brightness-110`}>
                        <tag.icon class="size-4" />
                        {tag.name}
                      </span>
                    </li>
                  )
                })}
              </ul>
              <div class="mt-2 text-white/70 leading-relaxed description">{description[lang]}</div>
              <footer class="flex items-end justify-start mt-4 gap-x-4">
                {github && (
                  <LinkButton href={github} extraClasses="buttons" ariaLabel={`${t('project.code')}: ${title}`}>
                    <Githubicon class="size-6" />
                    {t('project.code')}
                  </LinkButton>
                )}
                {link && (
                  <LinkButton href={link} extraClasses="buttons" ariaLabel={`${t('project.view')}: ${title}`}>
                    {t('project.view')}
                  </LinkButton>
                )}
              </footer>
            </div>
          </div>
        </article>
      ))
    }
  </div>
  <script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger,SplitText);

  gsap.from('#pj', {
    scrollTrigger: {
      trigger: '#pj',
      start: 'top 100%',
    },
    opacity: 0,
    y: 50,
    duration: 0.7,
  });

  const boxes = document.querySelectorAll('.box-container')
  boxes.forEach((box) => {

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: box,
        start: 'top 90%',
      },
    })
    const title = box.querySelector('.title');
    const chips = box.querySelectorAll('.chips');
    const buttons = box.querySelectorAll('.buttons');
    const description = box.querySelector('.description');
    const splitDescription = SplitText.create(description, { type: 'lines' });


    tl.from(box, {
      y: 50,
      opacity: 0,
      duration: 1,
      ease: 'power2.out',
    })

    tl.from(title, {
      y: 50,
      opacity: 0,
      duration: 1,
      stagger: 0.5,
    }, '<')
      .from(chips, {
        y: 50,
        opacity: 0,
        duration: 1,
        stagger: 0.3,
      }, '<')
      .from(splitDescription.lines, {
        y: 50,
        autoAlpha: 0,
        duration: 1,
        stagger: 0.3,
      })
      .from(buttons, {
        y: 50,
        opacity: 0,
        duration: 1,
        stagger: 0.3,
      }, '-=1');

  });


  </script>
</section>
