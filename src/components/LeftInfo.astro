---
import Githubicon from './icons/Githubicon.astro'
import LinkedinIcon from './icons/LinkedinIcon.astro'
import { useTranslations, type Lang } from '../i18n/ui'

const { lang } = Astro.props as { lang: Lang }
const t = useTranslations(lang)
---

<!-- Íconos fijos en escritorio -->
<div class="hidden lg:block fixed left-12 bottom-0 extras">
  <ul class="flex flex-col gap-4 justify-center items-center
    after:h-32 after:w-0.5 after:bg-white/80 after:rounded-full after:mt-4">
    <li>
      <a href="https://github.com/FrankoFPM" target="_blank" rel="noopener" aria-label="GitHub"
        class="flex items-center justify-center w-12 h-12 text-white/80 hover:text-secondary transition hover:-translate-y-1.5 duration-200 outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-full">
        <Githubicon class="size-10" />
      </a>
    </li>
    <li>
      <a href="https://www.linkedin.com/in/franco-perez-melgarejo/" target="_blank" rel="noopener" aria-label="LinkedIn"
        class="flex items-center justify-center w-12 h-12 text-white/80 hover:text-secondary transition hover:-translate-y-1.5 duration-200 outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-full">
        <LinkedinIcon class="size-10" />
      </a>
    </li>
  </ul>
</div>

<!-- Footer inferior para móviles -->
<div class="lg:hidden w-full bg-background/70 backdrop-blur-sm z-40 extras">
  <ul class="flex justify-center gap-8 py-3">
    <li>
      <a href="https://github.com/FrankoFPM" target="_blank" rel="noopener" aria-label="GitHub"
        class="text-white/80 hover:text-secondary transition hover:-translate-y-1 duration-200 outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-full">
        <Githubicon class="size-8" />
      </a>
    </li>
    <li>
      <a href="https://www.linkedin.com/in/franco-perez-melgarejo/" target="_blank" rel="noopener" aria-label="LinkedIn"
        class="text-white/80 hover:text-secondary transition hover:-translate-y-1 duration-200 outline-none focus-visible:ring-2 focus-visible:ring-secondary rounded-full">
        <LinkedinIcon class="size-8" />
      </a>
    </li>
  </ul>
</div>

<!-- Footer visible en todas las resoluciones -->
<footer class="relative w-full text-center my-10 p-4 text-white/60 text-sm">
  <p class="extras">&copy; {new Date().getFullYear()} Franco Pérez. {t('footer.rights')}</p>
  <p class="extras mt-1 text-white/40 text-xs">
    {t('footer.thirdparty')}
  </p>
</footer>
<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { DrawSVGPlugin } from 'gsap/DrawSVGPlugin'

  gsap.registerPlugin(ScrollTrigger, DrawSVGPlugin)

  // Animación de los íconos en el footer
  const icons = document.querySelectorAll('.extras');
  icons.forEach(icon => {
    gsap.from(icon, {
      duration: 0.5,
      y: 30,
      opacity: 0,
      ease: 'power1.out',
      scrollTrigger: {
        trigger: icon,
      }
    });
  });
</script>
